# App
APP_NAME=deep-research-agent

# OpenAI-compatible LLM provider
# Examples:
# - https://api.openai.com/v1
# - https://openrouter.ai/api/v1
# - http://localhost:8000/v1
LLM_BASE_URL=https://your-openai-compatible-endpoint/v1
LLM_API_KEY=your-api-key
# Alternative aliases for LLM credentials (used if LLM_* are not set)
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
PLANNER_MODEL=gpt-4.1-mini
SYNTHESIS_MODEL=gpt-4.1-mini

# Search providers (at least one required for web search)
TAVILY_API_KEY=your-tavily-api-key
BRAVE_API_KEY=your-brave-api-key
SERPER_API_KEY=your-serper-api-key

# Fetch fallbacks (optional; used when direct fetch fails)
JINA_API_KEY=your-jina-api-key
FIRECRAWL_API_KEY=your-firecrawl-api-key
ENABLE_JINA_READER_FALLBACK=false
ENABLE_FIRECRAWL_FALLBACK=false
JINA_TIMEOUT_SECONDS=20
FIRECRAWL_TIMEOUT_SECONDS=25

# Runtime
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELOAD=true
CHECKPOINT_DB_PATH=research.db
RUNS_DB_PATH=research_runs.db
FETCH_TIMEOUT_SECONDS=15
DEFAULT_MAX_ITERATIONS=2
DEFAULT_MAX_PARALLEL_TASKS=3
SEARCH_MAX_RESULTS=3

# Synthesis limits
SYNTHESIS_SOFT_CHAR_LIMIT=90000
SYNTHESIS_HARD_CHAR_LIMIT=110000
SYNTHESIS_MAX_FINDINGS_PER_CALL=24
SYNTHESIS_MAX_SOURCES_PER_CALL=12

# Feature switches
ENABLE_LLM_PLANNING=true
ENABLE_LLM_SYNTHESIS=true
REQUIRE_HUMAN_REVIEW=false
